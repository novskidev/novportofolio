---
import Icon from '../Icon.astro';

interface DoingItem {
  text: string;
  mark: string;
  href?: string;
  meta?: string;
}

const { items } = Astro.props as { items: DoingItem[] };
---

<article class="glass-card doing-card">
  <h2><Icon name="calendar" /> Recently</h2>
  <ul>
    {
      items.map((item) => (
        <li class:list={[{ linked: Boolean(item.href) }]}>
          {item.href ? (
            <a href={item.href}>
              <span>
                {item.meta && <small>{item.meta}</small>}
                {item.text}
              </span>
              <strong aria-hidden="true">{item.mark}</strong>
            </a>
          ) : (
            <>
              <span>
                {item.meta && <small>{item.meta}</small>}
                {item.text}
              </span>
              <strong aria-hidden="true">{item.mark}</strong>
            </>
          )}
        </li>
      ))
    }
  </ul>
</article>

<style>
  .doing-card {
    padding: 24px 0 0;
    border-color: transparent;
    background: transparent;
    box-shadow: none;
  }

  .doing-card:hover {
    border-color: transparent;
    box-shadow: none;
    transform: none;
  }

  h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 16px;
    color: var(--paper-ink);
    font-size: 1.06rem;
  }

  h2 svg {
    width: 21px;
    height: 21px;
    color: var(--paper-accent);
  }

  ul {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 32px;
    gap: 12px;
    align-items: center;
    padding: 14px 0 14px 18px;
    border-top: 1px solid var(--paper-line);
    color: var(--paper-ink);
    font-size: 0.98rem;
  }

  li.linked {
    grid-template-columns: 1fr;
    padding-right: 0;
  }

  a {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 48px;
    gap: 12px;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }

  a:hover,
  a:focus-visible {
    color: var(--paper-accent);
    outline: none;
  }

  small {
    display: block;
    margin-bottom: 2px;
    color: var(--paper-ink-faint);
    font-family: var(--font-ui-label);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  li::before {
    position: absolute;
    left: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--paper-accent);
    content: '';
  }

  strong {
    font-size: 0.82rem;
    text-align: right;
  }
</style>
