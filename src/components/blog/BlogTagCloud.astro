---
import type { ContentGroup } from '../../utils/content-groups';

interface Props {
  tags: ContentGroup[];
}

const { tags } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const maxTagCount = Math.max(1, ...tags.map((tag) => tag.count));
---

{
  tags.length > 0 && (
    <section class="blog-tag-cloud" aria-label="Blog tag cloud">
      <div class="tag-cloud-list">
        {tags.map((tag) => (
          <a
            href={`${basePath}/blog/tags/${tag.slug}/`}
            style={`--tag-weight: ${tag.count / maxTagCount}`}
          >
            <span>#{tag.name}</span>
            <small>{tag.count}</small>
          </a>
        ))}
      </div>
    </section>
  )
}

<style>
  .blog-tag-cloud {
    display: grid;
    gap: 13px;
    padding: 16px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: color-mix(in srgb, var(--paper-control) 72%, transparent);
  }

  .tag-cloud-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .tag-cloud-list a {
    display: inline-flex;
    gap: 6px;
    align-items: baseline;
    padding: 6px 9px;
    border: 1px solid var(--paper-line);
    border-radius: 999px;
    background: var(--paper-surface);
    color: var(--paper-ink);
    font-family: var(--font-page-heading);
    font-size: calc(0.78rem + var(--tag-weight) * 0.36rem);
    line-height: 1.1;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .tag-cloud-list a:hover {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    color: var(--paper-accent);
    transform: translateY(-1px);
  }

  .tag-cloud-list small {
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.68rem;
    font-weight: 700;
  }
</style>
