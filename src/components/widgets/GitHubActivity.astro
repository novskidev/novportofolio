---
interface Props {
  username: string;
  weeks?: number;
}

const { username, weeks = 18 } = Astro.props;
---

<article
  class="glass-card github-activity-card"
  data-github-activity
  data-github-username={username}
  data-github-weeks={weeks}
>
  <div class="stats-row" aria-live="polite">
    <div class="stat-item">
      <strong data-github-total>--</strong>
      <span>GitHub events</span>
    </div>
    <div class="stat-item">
      <strong data-github-days>--</strong>
      <span>Active days</span>
    </div>
    <div class="stat-item">
      <strong data-github-streak>--</strong>
      <span>Day streak</span>
    </div>
  </div>

  <aside class="latest-tip" aria-label="Latest GitHub activity" data-github-latest>
    <strong>Latest</strong>
    <p>Loading GitHub activity...</p>
  </aside>

  <div class="rhythm-grid" aria-label="Recent GitHub activity">
    <div class="weekday-column" aria-hidden="true">
      <span>Mon</span>
      <span>Wed</span>
      <span>Fri</span>
    </div>

    <div class="heatmap-cells" style={`--week-count: ${weeks};`} data-github-cells></div>
  </div>

  <footer>
    <span>Less</span>
    {[0, 1, 2, 3, 4].map((level) => <i class={`heatmap-cell level-${level}`} />)}
    <span>More</span>
  </footer>
</article>

<script>
  type GitHubEvent = {
    type: string;
    created_at: string;
    repo?: {
      name?: string;
    };
    payload?: {
      action?: string;
      ref_type?: string;
      commits?: unknown[];
      pull_request?: { title?: string };
      issue?: { title?: string };
    };
  };

  const DAY_IN_MS = 24 * 60 * 60 * 1000;

  function getDateKey(date: Date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');

    return `${year}-${month}-${day}`;
  }

  function getStartOfWeek(date: Date) {
    const start = new Date(date);
    const dayOffset = (start.getDay() + 6) % 7;
    start.setHours(0, 0, 0, 0);
    start.setDate(start.getDate() - dayOffset);

    return start;
  }

  function getLevel(count: number) {
    if (count === 0) return 0;
    if (count === 1) return 1;
    if (count <= 3) return 2;
    if (count <= 6) return 3;
    return 4;
  }

  function getEventLabel(event: GitHubEvent) {
    const repo = event.repo?.name?.split('/')[1] ?? event.repo?.name ?? 'GitHub';
    const action = event.payload?.action;

    if (event.type === 'PushEvent') {
      const commits = event.payload?.commits?.length ?? 0;
      return `Pushed ${commits || ''} commit${commits === 1 ? '' : 's'} to ${repo}`.replace(
        /\s+/g,
        ' ',
      );
    }

    if (event.type === 'PullRequestEvent') {
      return `${action ? `${action[0]?.toUpperCase()}${action.slice(1)}` : 'Updated'} pull request in ${repo}`;
    }

    if (event.type === 'IssuesEvent') {
      return `${action ? `${action[0]?.toUpperCase()}${action.slice(1)}` : 'Updated'} issue in ${repo}`;
    }

    if (event.type === 'CreateEvent') {
      return `Created ${event.payload?.ref_type ?? 'item'} in ${repo}`;
    }

    if (event.type === 'WatchEvent') {
      return `Starred ${repo}`;
    }

    if (event.type === 'ForkEvent') {
      return `Forked ${repo}`;
    }

    return `${event.type.replace(/Event$/, '')} in ${repo}`;
  }

  function getRepoHref(event: GitHubEvent) {
    return event.repo?.name
      ? `https://github.com/${event.repo.name}`
      : 'https://github.com/novskidev';
  }

  function renderEmptyCells(root: HTMLElement, weeks: number) {
    const cells = root.querySelector<HTMLElement>('[data-github-cells]');
    if (!cells) return;

    cells.replaceChildren();
    cells.style.setProperty('--week-count', String(weeks));

    for (let index = 0; index < weeks * 7; index += 1) {
      const cell = document.createElement('span');
      cell.className = 'heatmap-cell level-0';
      cells.append(cell);
    }
  }

  function renderActivity(root: HTMLElement, events: GitHubEvent[]) {
    const weeks = Number(root.dataset.githubWeeks || 18);
    const total = root.querySelector<HTMLElement>('[data-github-total]');
    const days = root.querySelector<HTMLElement>('[data-github-days]');
    const streak = root.querySelector<HTMLElement>('[data-github-streak]');
    const latest = root.querySelector<HTMLElement>('[data-github-latest]');
    const cells = root.querySelector<HTMLElement>('[data-github-cells]');
    const eventsByDate = new Map<string, GitHubEvent[]>();

    for (const event of events) {
      const key = getDateKey(new Date(event.created_at));
      const dayEvents = eventsByDate.get(key) ?? [];
      dayEvents.push(event);
      eventsByDate.set(key, dayEvents);
    }

    const today = new Date();
    today.setHours(0, 0, 0, 0);

    let currentStreak = 0;
    for (let date = new Date(today); ; date = new Date(date.valueOf() - DAY_IN_MS)) {
      if (!eventsByDate.has(getDateKey(date))) break;
      currentStreak += 1;
    }

    if (total) total.textContent = String(events.length);
    if (days) days.textContent = String(eventsByDate.size);
    if (streak) streak.textContent = String(currentStreak);

    if (latest) {
      const latestEvent = events[0];
      if (latestEvent) {
        const date = new Intl.DateTimeFormat('en', {
          month: 'short',
          day: 'numeric',
          year: 'numeric',
        }).format(new Date(latestEvent.created_at));

        latest.replaceChildren();
        const label = document.createElement('strong');
        const link = document.createElement('a');
        const title = document.createElement('em');
        const time = document.createElement('time');
        const icon = document.createElement('span');

        label.textContent = 'Latest';
        link.className = 'latest-link';
        link.href = getRepoHref(latestEvent);
        link.target = '_blank';
        link.rel = 'noreferrer';
        title.textContent = getEventLabel(latestEvent);
        time.dateTime = latestEvent.created_at;
        time.textContent = date;
        icon.className = 'latest-icon';
        icon.setAttribute('aria-hidden', 'true');
        icon.innerHTML =
          '<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>';

        link.append(title, time, icon);
        latest.append(label, link);
      } else {
        latest.innerHTML = '<strong>Latest</strong><p>No public GitHub activity found yet.</p>';
      }
    }

    if (!cells) return;
    cells.replaceChildren();
    cells.style.setProperty('--week-count', String(weeks));

    const start = getStartOfWeek(today);
    start.setDate(start.getDate() - (weeks - 1) * 7);

    for (let index = 0; index < weeks * 7; index += 1) {
      const date = new Date(start);
      date.setDate(start.getDate() + index);
      const key = getDateKey(date);
      const dayEvents = date > today ? [] : (eventsByDate.get(key) ?? []);
      const cell = document.createElement(dayEvents.length > 0 ? 'a' : 'span');
      const titleLines = dayEvents.slice(0, 5).map((event) => `- ${getEventLabel(event)}`);
      const title = [
        `${key}: ${dayEvents.length} GitHub event${dayEvents.length === 1 ? '' : 's'}`,
        ...titleLines,
      ].join('\n');

      cell.className = `heatmap-cell level-${getLevel(dayEvents.length)}`;
      cell.title = title;
      cell.setAttribute('aria-label', title);

      if (cell instanceof HTMLAnchorElement) {
        cell.href = `https://github.com/${root.dataset.githubUsername}`;
        cell.target = '_blank';
        cell.rel = 'noreferrer';
      }

      cells.append(cell);
    }
  }

  async function initGitHubActivity() {
    for (const root of document.querySelectorAll<HTMLElement>('[data-github-activity]')) {
      if (root.dataset.githubReady === 'true') continue;
      root.dataset.githubReady = 'true';

      const username = root.dataset.githubUsername;
      const weeks = Number(root.dataset.githubWeeks || 18);
      if (!username) continue;

      renderEmptyCells(root, weeks);

      try {
        const response = await fetch(
          `https://api.github.com/users/${username}/events/public?per_page=100`,
          {
            headers: { Accept: 'application/vnd.github+json' },
          },
        );

        if (!response.ok) throw new Error('GitHub activity request failed.');

        const events = (await response.json()) as GitHubEvent[];
        renderActivity(root, events);
      } catch {
        root.querySelector<HTMLElement>('[data-github-latest]')!.innerHTML =
          '<strong>Latest</strong><p>GitHub activity is temporarily unavailable.</p>';
      }
    }
  }

  initGitHubActivity();
  document.addEventListener('astro:page-load', initGitHubActivity);
</script>

<style>
  .github-activity-card {
    display: grid;
    gap: 16px;
    padding: 18px 0;
    border-color: transparent;
    background: transparent;
    box-shadow: none;
    overflow: visible;
  }

  .github-activity-card:hover {
    border-color: transparent;
    box-shadow: none;
    transform: none;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .stat-item {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .stat-item strong {
    color: var(--paper-ink);
    font-size: 1.12rem;
    line-height: 1;
  }

  .stat-item span {
    overflow: hidden;
    color: var(--paper-ink-soft);
    font-size: 0.72rem;
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .latest-tip {
    display: grid;
    gap: 6px;
    padding: 10px 11px;
    border: 1px solid var(--paper-line);
    border-radius: 7px;
    background: var(--paper-surface-muted);
  }

  .latest-tip strong {
    color: var(--paper-accent);
    font-size: 0.7rem;
    line-height: 1.15;
  }

  .latest-tip p {
    margin: 0;
    color: var(--paper-ink-soft);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .latest-tip :global(.latest-link) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) max-content 24px;
    align-items: center;
    min-width: 0;
    gap: 8px;
    color: inherit;
    text-decoration: none;
  }

  .latest-tip :global(.latest-link em) {
    overflow: hidden;
    color: var(--paper-ink);
    font-size: 0.8rem;
    font-style: normal;
    font-weight: 650;
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .latest-tip :global(.latest-link time) {
    color: var(--paper-ink-soft);
    font-size: 0.68rem;
    line-height: 1;
    white-space: nowrap;
  }

  .latest-tip :global(.latest-icon) {
    display: grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border-radius: 8px;
    color: var(--paper-accent);
    transition:
      background 180ms ease,
      transform 180ms ease;
  }

  .latest-tip :global(.latest-link:hover .latest-icon),
  .latest-tip :global(.latest-link:focus-visible .latest-icon) {
    background: var(--paper-control-hover);
    transform: translateY(-1px);
  }

  .rhythm-grid {
    --cell-size: 8px;
    --cell-gap: 2.5px;
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr);
    gap: 8px;
    align-items: center;
    width: 100%;
    max-width: 100%;
    overflow: visible;
  }

  .weekday-column {
    display: grid;
    grid-template-rows: repeat(3, var(--cell-size));
    gap: calc(var(--cell-size) + var(--cell-gap));
    color: var(--paper-ink-faint);
    font-size: 0.62rem;
    line-height: 1;
  }

  .heatmap-cells {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, var(--cell-size));
    grid-auto-columns: var(--cell-size);
    gap: var(--cell-gap);
    width: calc(
      (var(--cell-size) * var(--week-count)) + (var(--cell-gap) * (var(--week-count) - 1))
    );
    max-width: 100%;
  }

  .github-activity-card :global(.heatmap-cell) {
    display: block;
    width: var(--cell-size);
    height: var(--cell-size);
    min-width: 8px;
    min-height: 8px;
    border: 1px solid color-mix(in srgb, var(--paper-line) 76%, transparent);
    border-radius: 2px;
    background: var(--paper-control);
  }

  .github-activity-card :global(a.heatmap-cell:hover),
  .github-activity-card :global(a.heatmap-cell:focus-visible) {
    outline: 1px solid var(--paper-line-strong);
    outline-offset: 1px;
  }

  .github-activity-card :global(.heatmap-cell.level-0) {
    background: var(--paper-control);
  }

  .github-activity-card :global(.heatmap-cell.level-1) {
    background: color-mix(in srgb, var(--paper-accent) 22%, var(--paper-control));
  }

  .github-activity-card :global(.heatmap-cell.level-2) {
    background: color-mix(in srgb, var(--paper-accent) 42%, var(--paper-control));
  }

  .github-activity-card :global(.heatmap-cell.level-3) {
    background: color-mix(in srgb, var(--paper-accent) 66%, var(--paper-control));
  }

  .github-activity-card :global(.heatmap-cell.level-4) {
    background: var(--paper-accent);
  }

  footer {
    display: flex;
    gap: 5px;
    align-items: center;
    color: var(--paper-ink-faint);
    font-size: 0.68rem;
    line-height: 1;
  }
</style>
