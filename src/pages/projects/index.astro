---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import BlogTopNav from '../../components/blog/BlogTopNav.astro';
import { getSiteConfig } from '../../data/site';
import { sortByDateDesc } from '../../utils/content-dates';

const { site, theme } = await getSiteConfig();
const palette = theme.palette;
const projects = sortByDateDesc(await getCollection('projects', ({ data }) => !data.draft));

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<!doctype html>
<html lang="en" data-palette={palette}>
  <head>
    <BaseHead title={`projects | ${site.title}`} description="Selected work and project notes." />
    <style>
      main {
        width: min(100%, var(--layout-reading-width));
        padding: var(--layout-page-top) var(--layout-page-gutter) var(--layout-page-bottom);
      }

      .project-hero {
        display: grid;
        gap: 12px;
        margin-bottom: 34px;
      }

      .project-kicker,
      .project-meta,
      .project-empty span,
      .project-tags small {
        font-family: var(--font-ui-label);
      }

      .project-kicker,
      .project-meta,
      .project-empty span {
        color: var(--paper-ink-faint);
        font-size: 0.76rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        color: var(--paper-ink);
        font-size: clamp(2.35rem, 7vw, 4.4rem);
        font-weight: 400;
        letter-spacing: -0.06em;
        line-height: 0.95;
      }

      .project-hero p,
      .project-card p,
      .project-empty p {
        margin: 0;
        color: var(--paper-ink-soft);
        line-height: 1.78;
      }

      .project-hero p {
        max-width: 58ch;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .project-card,
      .project-empty {
        border: 1px solid var(--paper-line);
        border-radius: 8px;
        background: var(--paper-surface);
        box-shadow: var(--paper-shadow);
      }

      .project-card {
        display: grid;
        gap: 12px;
        min-height: 210px;
        padding: 22px;
        color: var(--paper-ink);
        text-decoration: none;
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          background 180ms ease;
      }

      .project-card:hover {
        border-color: var(--paper-line-strong);
        background: var(--paper-control-hover);
        transform: translateY(-1px);
      }

      .project-card h2,
      .project-empty h2 {
        margin: 0;
        color: var(--paper-ink);
        font-size: 1.32rem;
        line-height: 1.28;
      }

      .project-card p {
        max-width: 58ch;
      }

      .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-self: end;
      }

      .project-tags small {
        padding: 3px 8px;
        border: 1px solid var(--paper-line);
        border-radius: 999px;
        color: var(--paper-ink-soft);
        font-size: 0.74rem;
      }

      .project-empty {
        display: grid;
        gap: 10px;
        padding: 24px;
      }

      @media (max-width: 720px) {
        main {
          padding-top: 88px;
        }

        .project-grid {
          grid-template-columns: 1fr;
        }

        .project-card,
        .project-empty {
          padding: 20px;
        }
      }
    </style>
  </head>
  <body>
    <BlogTopNav />
    <main id="main-content" data-pagefind-body>
      <header class="project-hero">
        <p class="project-kicker">Project shelf</p>
        <h1>Projects</h1>
        <p>Selected work, experiments, and project notes will appear here.</p>
      </header>

      {
        projects.length > 0 ? (
          <section class="project-grid" aria-label="Projects">
            {projects.map((project) => (
              <a class="project-card" href={withBase(`/projects/${project.id}/`)}>
                <span class="project-meta">
                  <FormattedDate date={project.data.date} />
                </span>
                <h2>{project.data.title}</h2>
                <p>{project.data.description}</p>
                {project.data.tags.length > 0 && (
                  <span class="project-tags" aria-label="Project tags">
                    {project.data.tags.slice(0, 3).map((tag) => (
                      <small>{tag}</small>
                    ))}
                  </span>
                )}
              </a>
            ))}
          </section>
        ) : (
          <section class="project-empty" aria-label="Projects empty state">
            <span aria-hidden="true">00</span>
            <h2>No projects yet.</h2>
            <p>
              Create a new project entry in <code>src/content/projects</code> when you are ready.
            </p>
          </section>
        )
      }
    </main>
    <Footer />
  </body>
</html>
