{
  "name": "novskidev",
  "type": "module",
  "version": "0.2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "content:check": "bun scripts/validate-content.ts",
    "build": "bun scripts/validate-content.ts && astro build && pagefind --site dist --output-subdir pagefind --root-selector main --exclude-selectors \"[data-pagefind-ignore]\" --force-language en",
    "preview": "astro preview",
    "astro": "astro",
    "post:new": "bun scripts/new-content.ts blog",
    "project:new": "bun scripts/new-content.ts project",
    "vibe:new": "bun scripts/new-content.ts vibe",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "bun run lint && prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.44.0",
    "@expressive-code/plugin-line-numbers": "^0.44.0",
    "@fontsource/maple-mono": "^5.2.6",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "astro-expressive-code": "^0.44.0",
    "lucide-astro": "^0.556.0",
    "motion": "^12.42.0",
    "sharp": "^0.35.2",
    "smol-toml": "^1.7.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.62.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*": "bun run format:check"
  }
}
