---
import { Check, Link2 } from 'lucide-astro';

interface Props {
  title: string;
  description?: string;
  class?: string;
}

const { title, description = '', class: className } = Astro.props;
const shareDescription = description || `Read ${title}`;
const pageUrl = Astro.url.toString();
const encodedPageUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);
const encodedThreadText = encodeURIComponent(`${title} ${pageUrl}`);
const shareTargets = [
  {
    label: 'Facebook',
    target: 'facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedPageUrl}`,
  },
  {
    label: 'Threads',
    target: 'threads',
    href: `https://www.threads.net/intent/post?text=${encodedThreadText}`,
  },
  {
    label: 'X',
    target: 'x',
    href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedPageUrl}`,
  },
  {
    label: 'LinkedIn',
    target: 'linkedin',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedPageUrl}`,
  },
];
---

<section
  class:list={['share-actions', className]}
  aria-label="Share this page"
  data-pagefind-ignore
  data-share-actions
  data-share-title={title}
  data-share-description={shareDescription}
  data-share-url={pageUrl}
>
  <div class="share-row">
    <span class="share-label">Share:</span>
    <nav class="share-links" aria-label="Share destinations">
      {
        shareTargets.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noreferrer"
            aria-label={`Share on ${item.label}`}
            title={`Share on ${item.label}`}
            data-share-target={item.target}
          >
            {item.target === 'facebook' && (
              <svg class="share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M13.5 22v-8h2.7l.4-3.1h-3.1V8.9c0-.9.2-1.5 1.5-1.5h1.7V4.6c-.3 0-1.3-.1-2.4-.1-2.4 0-4.1 1.5-4.1 4.2v2.3H7.5V14h2.7v8h3.3z" />
              </svg>
            )}
            {item.target === 'threads' && (
              <svg class="share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M12.19 24h-.01c-3.58-.02-6.33-1.2-8.18-3.51C2.35 18.44 1.5 15.59 1.47 12.01v-.02C1.5 8.41 2.35 5.56 4 3.51 5.85 1.2 8.6.02 12.18 0h.02c2.75.02 5.04.73 6.83 2.1 1.68 1.29 2.86 3.13 3.51 5.47l-2.04.57c-1.1-3.96-3.9-5.99-8.3-6.02-2.91.02-5.11.94-6.54 2.72C4.31 6.5 3.62 8.91 3.59 12c.03 3.09.72 5.5 2.06 7.16 1.43 1.78 3.63 2.7 6.54 2.72 2.62-.02 4.36-.63 5.8-2.04 1.65-1.61 1.62-3.59 1.08-4.75-.32-.68-.89-1.22-1.65-1.6-.19 1.35-.62 2.45-1.28 3.27-.89 1.1-2.14 1.7-3.73 1.79-1.2.07-2.36-.22-3.26-.8-1.06-.69-1.69-1.74-1.75-2.96-.13-2.38 1.75-4.08 4.69-4.23 1.05-.05 2.04 0 2.94.14-.12-.73-.36-1.3-.73-1.71-.54-.59-1.35-.9-2.41-.91h-.03c-.86 0-2.03.24-2.77 1.36L7.3 8.25C8.28 6.8 9.87 6 11.78 6h.04c3.19.05 5.17 2.07 5.42 5.54 1.51.57 2.62 1.52 3.17 2.69.85 1.82.93 4.78-1.51 7.17C17.78 23.16 15.46 23.98 12.19 24zm0-11.34c-.33 0-.67.01-1.01.03-1.68.08-2.63.82-2.59 1.99.05 1 1.08 1.72 2.45 1.72h.2c1.84-.1 2.96-1.21 3.33-3.29-.69-.29-1.5-.45-2.38-.45z" />
              </svg>
            )}
            {item.target === 'x' && (
              <svg class="share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.47l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93zm-1.29 19.49h2.04L6.49 3.24H4.3l13.31 17.4z" />
              </svg>
            )}
            {item.target === 'linkedin' && (
              <svg class="share-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.11 20.45H3.56V9h3.55v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.23 0z" />
              </svg>
            )}
            <span class="share-sr-only">Share on {item.label}</span>
          </a>
        ))
      }
    </nav>
    <button type="button" data-copy-link-button aria-label="Copy page link">
      <Link2 size={17} stroke-width={2} />
      <span class="share-sr-only">Copy link</span>
    </button>
  </div>

  <p class="share-status" aria-live="polite" data-share-status>
    <Check size={15} stroke-width={2} />
    <span></span>
  </p>
</section>

<script>
  const initShareActions = () => {
    for (const root of document.querySelectorAll<HTMLElement>('[data-share-actions]')) {
      if (root.dataset.shareReady === 'true') {
        continue;
      }

      root.dataset.shareReady = 'true';

      const title = root.dataset.shareTitle || document.title;
      const shareLinks = root.querySelectorAll<HTMLAnchorElement>('[data-share-target]');
      const copyButton = root.querySelector<HTMLButtonElement>('[data-copy-link-button]');
      const status = root.querySelector<HTMLElement>('[data-share-status]');
      const statusText = status?.querySelector('span');
      let statusTimer = 0;

      const getShareUrl = () => window.location.href;

      const getShareHref = (target: string, url: string) => {
        const encodedUrl = encodeURIComponent(url);
        const encodedTitle = encodeURIComponent(title);
        const encodedThreadText = encodeURIComponent(`${title} ${url}`);

        if (target === 'facebook') {
          return `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
        }

        if (target === 'threads') {
          return `https://www.threads.net/intent/post?text=${encodedThreadText}`;
        }

        if (target === 'x') {
          return `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
        }

        if (target === 'linkedin') {
          return `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
        }

        return url;
      };

      const syncShareLinks = () => {
        const url = getShareUrl();

        for (const link of shareLinks) {
          link.href = getShareHref(link.dataset.shareTarget || '', url);
        }
      };

      const setStatus = (message: string) => {
        if (!status || !statusText) {
          return;
        }

        window.clearTimeout(statusTimer);
        statusText.textContent = message;
        root.dataset.shareStatus = message ? 'visible' : 'idle';

        if (message) {
          statusTimer = window.setTimeout(() => {
            statusText.textContent = '';
            root.dataset.shareStatus = 'idle';
          }, 2400);
        }
      };

      const copyText = async (value: string) => {
        if (window.isSecureContext && navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(value);
          return;
        }

        const textarea = document.createElement('textarea');
        textarea.value = value;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.top = '0';
        textarea.style.left = '-9999px';
        document.body.append(textarea);
        textarea.focus();
        textarea.select();

        const didCopy = document.execCommand('copy');
        textarea.remove();

        if (!didCopy) {
          throw new Error('Copy command failed');
        }
      };

      const copyLink = async () => {
        try {
          await copyText(getShareUrl());
          setStatus('Link copied');
        } catch {
          setStatus('Copy failed');
        }
      };

      syncShareLinks();
      copyButton?.addEventListener('click', copyLink);
    }
  };

  initShareActions();
  document.addEventListener('astro:page-load', initShareActions);
</script>

<style>
  .share-actions {
    position: relative;
    width: min(100%, var(--article-content-max, 720px));
    margin-top: 42px;
    padding: 14px 16px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-surface);
    box-shadow: var(--paper-shadow);
  }

  .share-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .share-label {
    color: var(--paper-ink);
    font-family: var(--font-meta);
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .share-links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  a,
  button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    font-family: var(--font-meta);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  button {
    gap: 7px;
  }

  .share-icon {
    width: 17px;
    height: 17px;
    fill: currentColor;
  }

  .share-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  a:hover,
  a:focus-visible,
  button:hover,
  button:focus-visible {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    color: var(--paper-accent);
    transform: translateY(-1px);
  }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--paper-accent);
    outline-offset: 2px;
  }

  .share-status {
    position: absolute;
    right: 14px;
    bottom: -14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    padding: 5px 9px;
    border: 1px solid var(--paper-line);
    border-radius: 999px;
    background: var(--paper-nav);
    color: var(--paper-accent);
    font-family: var(--font-meta);
    font-size: 0.72rem;
    font-weight: 800;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-4px);
    transition:
      opacity 160ms ease,
      transform 160ms ease;
  }

  .share-actions[data-share-status='visible'] .share-status {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .share-actions {
      margin-top: 34px;
      padding: 14px;
    }

    a,
    button {
      width: 38px;
      height: 38px;
    }

    .share-status {
      right: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    a,
    button,
    .share-status {
      transition: none;
    }

    a:hover,
    a:focus-visible,
    button:hover,
    button:focus-visible {
      transform: none;
    }
  }
</style>
