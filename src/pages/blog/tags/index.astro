---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import BackLink from '../../../components/blog/BackLink.astro';
import BlogTopNav from '../../../components/blog/BlogTopNav.astro';
import { getSiteConfig } from '../../../data/site';
import { getAllTags } from '../../../utils/content-groups';

const { site, theme } = await getSiteConfig();
const palette = theme.palette;
const tags = getAllTags(await getCollection('blog', ({ data }) => !data.draft));
const pageDescription = 'Browse blog posts by keyword tags.';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const maxTagCount = Math.max(1, ...tags.map((tag) => tag.count));
---

<!doctype html>
<html lang="en" data-palette={palette}>
  <head>
    <BaseHead title={`${site.title} | Tags`} description={pageDescription} />
    <style>
      main {
        width: min(100%, var(--layout-shell-width));
        max-width: none;
        padding: 118px var(--layout-page-gutter) var(--layout-page-bottom);
      }

      .tag-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .tag-cloud a {
        display: inline-flex;
        gap: 8px;
        align-items: baseline;
        padding: 9px 12px;
        border: 1px solid var(--paper-line);
        border-radius: 999px;
        background: var(--paper-control);
        color: var(--paper-ink);
        font-family: var(--font-page-heading);
        font-size: calc(0.9rem + var(--tag-weight) * 0.52rem);
        line-height: 1.1;
        text-decoration: none;
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          background 180ms ease,
          color 180ms ease;
      }

      .tag-cloud a:hover {
        border-color: var(--paper-line-strong);
        background: var(--paper-control-hover);
        color: var(--paper-accent);
        transform: translateY(-1px);
      }

      .tag-cloud small {
        color: var(--paper-ink-faint);
        font-family: var(--font-meta);
        font-size: 0.72rem;
        font-weight: 700;
      }

      .empty-note {
        max-width: 620px;
        margin: 0;
        color: var(--paper-ink-soft);
        font-family: var(--font-serif-cn);
        font-size: 1rem;
        line-height: 1.75;
      }

      @media (max-width: 720px) {
        main {
          padding-top: 88px;
        }

        .tag-cloud {
          align-items: stretch;
        }

        .tag-cloud a {
          width: 100%;
          justify-content: space-between;
        }
      }
    </style>
  </head>
  <body>
    <BlogTopNav />
    <main id="main-content" data-pagefind-body>
      <BackLink href="/blog/" label="Back to blog" />
      <header class="archive-hero archive-header-shared page-header-spacing">
        <div class="archive-header-main">
          <p class="archive-kicker">Browse notes</p>
          <h1 class="archive-title">Tags</h1>
        </div>
        <p class="archive-note">Small keyword labels gathered from article frontmatter.</p>
      </header>

      {
        tags.length > 0 ? (
          <section class="tag-cloud" aria-label="Blog tags">
            {tags.map((tag) => (
              <a
                href={`${basePath}/blog/tags/${tag.slug}/`}
                style={`--tag-weight: ${tag.count / maxTagCount}`}
              >
                <span>#{tag.name}</span>
                <small>{tag.count}</small>
              </a>
            ))}
          </section>
        ) : (
          <p class="empty-note">No tags have been added yet.</p>
        )
      }
    </main>
    <Footer />
  </body>
</html>
