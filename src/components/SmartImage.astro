---
import { Image } from 'astro:assets';
import type { HTMLAttributes } from 'astro/types';

interface Props extends Omit<HTMLAttributes<'img'>, 'src'> {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
}

const {
  src,
  alt,
  widths,
  sizes,
  loading = 'lazy',
  decoding = 'async',
  ...imageAttrs
} = Astro.props;
const shouldOptimize = typeof src !== 'string';
---

{
  shouldOptimize ? (
    <Image
      src={src}
      alt={alt}
      widths={widths}
      sizes={sizes}
      loading={loading}
      decoding={decoding}
      {...imageAttrs}
    />
  ) : (
    <img src={src} alt={alt} sizes={sizes} loading={loading} decoding={decoding} {...imageAttrs} />
  )
}
